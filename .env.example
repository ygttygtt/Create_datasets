# API Keys - 从你的 API 提供商获取
# 复制此文件为 .env 并填入你的真实 key

# Mimo API
MIMO_API_KEY=sk-your-mimo-key-here
MIMO_API_URL=https://fufu.iqach.top/v1
MIMO_MODEL=mimo-v2.5-pro

# Grok API
GROK_API_KEY=sk-your-grok-key-here
GROK_API_URL=https://ld.uzumakinoharu.top/v1
GROK_MODEL=grok-4.3-fast

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
